package com.example.navigationdrawerdemo;

import android.os.Bundle;
import android.widget.ArrayAdapter;

import androidx.fragment.app.ListFragment;

@SuppressWarnings("deprecation") // Tells Android Studio we know this is an older lab method
public class FragmentList extends ListFragment {

    @Override
    public void onActivityCreated(Bundle savedInstanceState) {
        super.onActivityCreated(savedInstanceState);

        // 1. Create the data for the list
        String[] items = {
                "Item 1", "Item 2", "Item 3", "Item 4",
                "Item 5", "Item 6", "Item 7", "Item 8",
                "Item 9", "Item 10"
        };

        // 2. Create the Adapter (the bridge between the data and the screen)
        ArrayAdapter<String> adapter = new ArrayAdapter<>(
                requireActivity(),
                android.R.layout.simple_list_item_1,
                items
        );

        // 3. Apply the adapter to the ListFragment
        setListAdapter(adapter);
    }
}